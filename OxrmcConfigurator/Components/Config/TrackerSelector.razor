@using System.Printing
@inject ConfigService ConfigService;

<MudChipSet SelectedValues="@_selected" SelectedValuesChanged="OnSelectedValuesChanged" Mandatory="true" Filter="true">
	<MudChip Text="Unknown" Style="@(SelectedTracker == Tracker.Error ? string.Empty : "display: none")" Value="@Tracker.Error" />
	<MudChip Text="Motion Controller" Value="@Tracker.Controller" />
	<MudChip Text="HTC Vive Tracker" Value="@Tracker.Vive"/>
	<MudChip Text="Sim Racing Studio" Value="@Tracker.Srs" />
	<MudChip Text="FlyPT Mover" Value="@Tracker.FlyPt"/>
	<MudChip Text="Yaw Built-in Sensors" Value="@Tracker.Yaw"/>
</MudChipSet>

@code {
	[CascadingParameter]
	private ConfigItem SelectedConfig { get; set; } = new(ConfigService.defaultApp);
	[CascadingParameter]
	public Tracker SelectedTracker { get; set; }
	[Parameter]
	public EventCallback<Tracker> OnTrackerChanged { get; set; }

	private ICollection<object> _selected = new List<object>() { Tracker.Error };
	private bool _isDefault;
	private string? _lastName;
	private bool _ignoreSelectionChange = false;
	
	private async Task UpdateTrackerFromConfig()
	{
		var trackerEntry = ("" == SelectedConfig.name) 
			? new ConfigEntry("", "", "", "") 
			: ConfigService.TryGetEntry(SelectedConfig.name, "tracker", "type");
		_isDefault = trackerEntry?.Default ?? true;
		var selectedTracker = trackerEntry?.Value switch
		{
			("controller") => Tracker.Controller,
			("vive") => Tracker.Vive,
			("srs") => Tracker.Srs,
			("flypt") => Tracker.FlyPt,
			("yaw") => Tracker.Yaw,
			_ => Tracker.Error
		};
		if (!OnTrackerChanged.HasDelegate) return;
		await OnTrackerChanged.InvokeAsync(selectedTracker);
	}	
	
	protected override async Task OnParametersSetAsync()
	{
		var oldSelection = _selected.First();
		if ((Tracker)oldSelection != SelectedTracker)
		{
			_selected.Clear();
			_selected.Add(SelectedTracker);
			_ignoreSelectionChange = true;
		}
		if (_lastName == SelectedConfig.name) return;
		await UpdateTrackerFromConfig();
		_lastName = SelectedConfig.name;
	}

	private async Task OnSelectedValuesChanged(IEnumerable<object> values)
	{
		if (_ignoreSelectionChange)
		{
			_ignoreSelectionChange = false;
			return;
		}
		var enumerable = values.ToList();
		_selected = enumerable.ToList();
		var type = (Tracker)enumerable.First() switch
		{
			Tracker.Controller => "controller",
			Tracker.Vive => "vive",
			Tracker.Srs => "srs",
			Tracker.FlyPt => "flypt",
			Tracker.Yaw => "yaw",
			Tracker.Error => "unknown", // TODO: handle error?
			_ => "unknown"
			};
		ConfigService.SetEntry(SelectedConfig.name, "tracker", "type", type);
		await UpdateTrackerFromConfig();
	}
}
