@using MudBlazor

<!--div Style="background-color: var(@BackgroundColor) !important;"-->
	<MudStack Class="d-flex xs-2 pa-1" Row="true" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
		<MudAvatar Style="height:90px; width:90px;" Elevation="12">
			<MudImage Src="@images[Index]" Fluid="true"/>
		</MudAvatar>
		<MudSpacer/>
		<MudStack Justify="Justify.FlexStart" Spacing="1">
			<MudText Typo="Typo.h4">@titles[Index]</MudText>
			<MudText Typo="Typo.body1">@descriptions[Index]</MudText>
			<MudText Typo="Typo.body2">@BackgroundColor</MudText>
		</MudStack>
	</MudStack>
<!--div-->
@code {
	static string[] images = { "images/controller.jpg", "images/vive.png", "images/srs.png", "images/flypt.png", "images/yaw.png" };
	static string[] titles = { "Motion Controller", "HTC Vive Tracker", "Sim Racing Studio", "FlyPT Mover", "Yaw VR" };
	static string[] descriptions =
	{
		"Use a handheld controller matching your VR hmd mounted onto your motion rig.",
		"Use a HTC Vive tracker mounted onto your motion rig.",
		"Use a Witmotion WT901C (RS232) sensor in combination with SimRacingStudio motion software.", 
		"Use FlyPT Mover's motion compensation output module.",
		"Use use YawVR or Yaw 2/2.5/3 built-in sensors."
	};

	[Parameter]
	public int Index { get; set; }

	string BackgroundColor = "--mud-palette-text-primary";

	public void OnTrackerChanged(int? newTracker)
	{
		BackgroundColor = newTracker == Index ? "--mud-palette-text-secondary" : "--mud-palette-text-primary";
		StateHasChanged();
	}
}
